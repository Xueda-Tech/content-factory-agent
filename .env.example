# =============================================================================
# Content Factory Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Required variables are marked with [REQUIRED]; others have sensible defaults.

# -----------------------------------------------------------------------------
# AI / SiliconFlow
# -----------------------------------------------------------------------------
# [REQUIRED] API key for SiliconFlow (https://siliconflow.cn).
# Used for topic analysis and content generation via chat completions.
# Get your key at: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key

# SiliconFlow model identifier.
# Default: deepseek-ai/DeepSeek-V3
# See https://docs.siliconflow.cn for available models.
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# -----------------------------------------------------------------------------
# WeChat Publishing (wx.limyai.com)
# -----------------------------------------------------------------------------
# [REQUIRED] WeChat Official Account AppID.
# Used to identify the target account when publishing via wx.limyai.com.
# Falls back to the request body's wechatAppid field if not set here.
WECHAT_APPID=your-wechat-appid

# -----------------------------------------------------------------------------
# WeChat Article Collection (dajiala.com)
# -----------------------------------------------------------------------------
# [REQUIRED] API key for dajiala.com WeChat article collection service.
# Used by the Topic Insight module to fetch WeChat articles.
DAJIALA_API_KEY=your-dajiala-api-key

# -----------------------------------------------------------------------------
# Xiaohongshu (Little Red Book) Publishing
# -----------------------------------------------------------------------------
# [REQUIRED] API key for Xiaohongshu publishing.
# Used to publish notes via the Xiaohongshu API.
XHS_API_KEY=your-xiaohongshu-api-key

# Base URL for the Xiaohongshu publishing API.
# Default: https://api.xiaohongshu.com
# Override this if using a proxy or self-hosted XHS API gateway.
# XHS_PUBLISH_API_URL=https://api.xiaohongshu.com

# -----------------------------------------------------------------------------
# Database  [PLANNED]
# -----------------------------------------------------------------------------
# Path to the SQLite database file.
# Currently hardcoded in src/lib/db.ts to ./data/content-factory.db.
# This variable is reserved for future configurability.
# DB_PATH=./data/content-factory.db
